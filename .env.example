# MrEric environment configuration
# Copy to .env and fill values for local dev. .env is gitignored.

# Phoenix
SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000

# AI provider (one of: openai, openrouter, grok, ollama, lmstudio)
#
# If AI_PROVIDER is unset, MrEric prefers a local LLM: at boot it probes
# LM Studio (http://localhost:1234/v1) -> Ollama (http://localhost:11434/v1)
# -> OpenAI in order and uses the first reachable one. Set AI_PROVIDER to pin a
# provider explicitly and skip the probe.
# AI_PROVIDER=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROK_API_KEY=
# Optional local endpoint overrides
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
