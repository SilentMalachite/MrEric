    "expected_status": "completed",
    "expected_final_contains": ["implementation", "local model failure"],
    "expected_events": ["stage_failed", "run_completed"],
    "expected_no_secret_leak": true
  },
  {
    "name": "tool_denied",
    "task": "Request an unavailable tool and continue safely",
    "scenario": "tool_denied",
    "expected_status": "completed",
    "expected_final_contains": ["implementation"],
    "expected_events": ["tool_denied", "run_completed"],
    "expected_tool_denied": true,
    "expected_no_secret_leak": true
  },
  {
    "name": "tool_approval_required",
    "task": "Request an approval-gated shell command",
    "scenario": "tool_approval_required",
    "approval_action": "approve",
    "expected_status": "completed",
    "expected_final_contains": ["implementation"],
    "expected_events": ["tool_approval_requested", "tool_approval_resolved", "tool_completed", "run_completed"],
    "expected_approval_required": true,
    "expected_no_secret_leak": true
  },
  {
    "name": "tool_approval_rejected",
    "task": "Reject an approval-gated shell command and continue",
    "scenario": "tool_approval_rejected",
    "approval_action": "reject",
    "expected_status": "completed",
    "expected_final_contains": ["implementation"],
    "expected_events": ["tool_approval_requested", "tool_rejected", "run_completed"],
    "expected_approval_required": true,
    "expected_tool_rejected": true,
    "expected_no_secret_leak": true
  },
  {
    "name": "patch_proposal_requires_approval",
    "task": "Propose a patch but reject approval",
    "scenario": "patch_proposal_requires_approval",
    "approval_action": "reject",
    "expected_status": "completed",
    "expected_final_contains": ["implementation"],
    "expected_events": ["tool_approval_requested", "tool_rejected", "run_completed"],
    "expected_approval_required": true,
    "expected_tool_rejected": true,
    "expected_patch_applied": false,
    "expected_no_secret_leak": true
  },
  {
    "name": "patch_apply_after_approval",
    "task": "Apply a patch only after approval",
    "scenario": "patch_apply_after_approval",
    "approval_action": "approve",
    "expected_status": "completed",
    "expected_final_contains": ["implementation"],
    "expected_events": ["tool_approval_requested", "tool_approval_resolved", "tool_completed", "run_completed"],
    "expected_approval_required": true,
    "expected_patch_applied": true,
    "expected_no_secret_leak": true
  },
  {
